# Claude (Anthropic) — story generation
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — DALL-E 3 image generation
OPENAI_API_KEY=sk-...

# Vercel Blob — permanent public image storage (required for TikTok/Instagram URLs)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Facebook & Instagram ───────────────────────────────────────────────────
# Both use the same Facebook App / Page setup.
# Get your Page Access Token:
#   GET https://graph.facebook.com/v21.0/me/accounts?access_token={USER_TOKEN}
# Get your Page ID from the same response.
FACEBOOK_PAGE_ID=123456789...
FACEBOOK_PAGE_ACCESS_TOKEN=EAAxxxxx...  # Page-level token (not user token)

# ── Instagram ──────────────────────────────────────────────────────────────
# 1. Create Facebook App at developers.facebook.com
# 2. Add Instagram Graph API product
# 3. Link Instagram Business/Creator account to a Facebook Page
# 4. Generate long-lived token with: instagram_basic, instagram_content_publish
INSTAGRAM_ACCOUNT_ID=17841400...
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...

# ── TikTok ─────────────────────────────────────────────────────────────────
# 1. Create app at developers.tiktok.com
# 2. Add Content Posting API product
# 3. Complete OAuth2 flow to get user access token
# Required scope: video.publish (for photo posts too)
TIKTOK_ACCESS_TOKEN=act.xxxxx...

# ── YouTube Shorts ─────────────────────────────────────────────────────────
# 1. Enable YouTube Data API v3 in Google Cloud Console
# 2. Create OAuth2 credentials (Desktop app)
# 3. Run: npx ts-node scripts/youtube-auth.ts   (one-time)
# 4. Copy the refresh token printed to your terminal
YOUTUBE_CLIENT_ID=xxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxx

# ── Amazon Affiliate ───────────────────────────────────────────────────────
# Sign up at affiliate-program.amazon.com
# Your tag looks like: yourname-20
AMAZON_AFFILIATE_TAG=yourname-20

# ── Substack ───────────────────────────────────────────────────────────────
# 1. Log into substack.com
# 2. DevTools → Application → Cookies → copy "substack.sid" value
# 3. Your publication URL e.g. https://yourbrand.substack.com
SUBSTACK_PUBLICATION_URL=https://yourbrand.substack.com
SUBSTACK_SID=your-session-cookie-value

# Cron security — random string, must match what's set in Vercel env vars
CRON_SECRET=your-random-secret-here
